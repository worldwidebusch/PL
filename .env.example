# LinkedIn OIDC application credentials. Configure the exact callback URL in
# the LinkedIn Developer Portal before enabling the production login button.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://example.com/api/v1/auth/linkedin/callback

# Facebook Login application credentials. Keep the Graph version configurable
# so upgrades can be tested before changing production.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=https://example.com/api/v1/auth/facebook/callback
FACEBOOK_GRAPH_VERSION=v23.0

# Public application origin. No path, query, or fragment.
PROLINKER_APP_ORIGIN=https://example.com

# Generate with a cryptographically secure password manager or secret tool.
# Use at least 32 random characters. Never expose this value to browser code.
PROLINKER_SESSION_SECRET=

# Optional previous secret for a controlled signing-key rotation.
PROLINKER_SESSION_SECRET_PREVIOUS=

# Signed-cookie preview sessions work without a database. For production
# preview access must be disabled. Local preview must opt in explicitly.
PROLINKER_ALLOW_PREVIEW_AUTH=false

# Private HTTPS backend adapter used by the API gateway, WhatsApp challenge
# operations, durable account storage, referrals, and staging compatibility.
# Keep the bearer token server-side and leave it blank in source control.
PROLINKER_BACKEND_ADAPTER_URL=
PROLINKER_BACKEND_ADAPTER_TOKEN=
PROLINKER_ADAPTER_TIMEOUT_MS=10000

# WhatsApp one-time-code policy. Delivery and rate limiting remain the
# responsibility of the private backend adapter.
PROLINKER_OTP_TTL_SECONDS=300
PROLINKER_OTP_RESEND_SECONDS=60
PROLINKER_OTP_MAX_ATTEMPTS=5
PROLINKER_TERMS_VERSION=2026-07-12
PROLINKER_PRIVACY_VERSION=2026-07-12

# Compatibility aliases for the existing LinkedIn identity adapter. New
# deployments should use the backend adapter variables above. These aliases
# remain available during a controlled migration and must never reach browser
# code.
PROLINKER_IDENTITY_ADAPTER_URL=
PROLINKER_IDENTITY_ADAPTER_TOKEN=

PROLINKER_SESSION_TTL_SECONDS=604800
PROLINKER_OAUTH_TTL_SECONDS=600
PROLINKER_REFERRAL_LINK_TTL_SECONDS=7776000
PROLINKER_REQUIRE_NONCE=true
PROLINKER_ALLOW_INSECURE_COOKIES=false
