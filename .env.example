# LinkedIn OIDC application credentials. Configure the exact callback URL in
# the LinkedIn Developer Portal before enabling the production login button.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://example.com/api/v1/auth/linkedin/callback

# Public application origin. No path, query, or fragment.
PROLINKER_APP_ORIGIN=https://example.com

# Generate with a cryptographically secure password manager or secret tool.
# Use at least 32 random characters. Never expose this value to browser code.
PROLINKER_SESSION_SECRET=

# Optional previous secret for a controlled signing-key rotation.
PROLINKER_SESSION_SECRET_PREVIOUS=

# Signed-cookie preview sessions work without a database. For production
# account linking, revocation, referral attribution, and durable profiles,
# point this at a private HTTPS identity adapter endpoint.
PROLINKER_IDENTITY_ADAPTER_URL=
PROLINKER_IDENTITY_ADAPTER_TOKEN=

PROLINKER_SESSION_TTL_SECONDS=604800
PROLINKER_OAUTH_TTL_SECONDS=600
PROLINKER_REFERRAL_LINK_TTL_SECONDS=7776000
PROLINKER_REQUIRE_NONCE=true
PROLINKER_ALLOW_INSECURE_COOKIES=false
